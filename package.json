{
  "name": "johannschopplich",
  "type": "module",
  "version": "1.0.2",
  "packageManager": "pnpm@10.33.0",
  "description": "Hi, I'm Johann. Developer with an eye for design.",
  "author": "Johann Schopplich <hello@johannschopplich.com>",
  "license": "MIT",
  "homepage": "https://github.com/johannschopplich/johannschopplich#readme",
  "repository": {
